# SchoolAssist - Environment Variables

# Database (PostgreSQL/Neon)
DATABASE_URL=postgresql://user:password@host.neon.tech/db?sslmode=require
DIRECT_URL=postgresql://user:password@host.neon.tech/db?sslmode=require

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Super Admin (for /api/superadmin/ routes)
SUPERADMIN_SECRET=schoolassist-superadmin-2026

# Telegram Bot (for notifications)
TELEGRAM_BOT_TOKEN=

# CallMeBot (for WhatsApp/Telegram notifications)
CALLMEBOT_API_KEY=